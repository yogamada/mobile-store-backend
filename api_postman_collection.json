{
	"info": {
		"_postman_id": "8f828a2a-b6b8-4c1b-9a7c-6e27ab2033bc",
		"name": "E-Commerce Laravel API",
		"description": "Collection untuk menguji REST API E-Commerce Laravel (Authentication, Products, dan Orders/Checkout).\n\n### Cara Penggunaan:\n1. Import file ini ke Postman.\n2. Jalankan request **Login** atau **Register** terlebih dahulu.\n3. Request **Login** memiliki script otomatis yang akan menyimpan JWT `access_token` ke dalam variabel collection `token`.\n4. Request lain (seperti Get Products, Checkout, dll) otomatis mewarisi (inherit) token tersebut, sehingga tidak perlu copy-paste token manual.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Register",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Budi Santoso\",\n    \"email\": \"budi@example.com\",\n    \"password\": \"password123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/auth/register",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"register"
							]
						},
						"description": "Mendaftarkan customer baru. Role otomatis diset sebagai 'customer'."
					},
					"response": []
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Otomatis simpan access_token ke variabel collection jika login sukses",
									"var responseData = pm.response.json();",
									"if (responseData.success && responseData.access_token) {",
									"    pm.collectionVariables.set(\"token\", responseData.access_token);",
									"    console.log(\"Token JWT berhasil disimpan ke variabel: \" + responseData.access_token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"budi@example.com\",\n    \"password\": \"password123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"login"
							]
						},
						"description": "Melakukan login dengan email dan password. Response berisi access_token JWT."
					},
					"response": []
				},
				{
					"name": "Get Profile (Me)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/auth/me",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"me"
							]
						},
						"description": "Mengambil data profil user yang sedang login menggunakan token JWT."
					},
					"response": []
				},
				{
					"name": "Logout",
